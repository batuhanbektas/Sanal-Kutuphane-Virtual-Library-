@model List<KutuphaneSatis.DTOs.Response.OrderResponse.OrderHistoryResponse>

@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container mt-5">
    <h2><i class="bi bi-box-seam"></i> Geçmiş Siparişlerim</h2>
    <hr />

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            Henüz bir siparişiniz bulunmamaktadır.
        </div>
    }
    else
    {
        <table class="table table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Sipariş Numarası</th>
                    <th>Tarih</th>
                    <th>Toplam Tutar</th>
                    <th>Detaylar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.OrderId</td>
                        <td>@order.OrderTime.ToString("dd.MM.yyyy")</td>
                        <td><span class="badge bg-success fs-6">@order.TotalPrice ₺</span></td>
                        <td>
                            <a asp-controller="Order" asp-action="GetOrderDetails" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-primary">
                                Detayları Gör
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>