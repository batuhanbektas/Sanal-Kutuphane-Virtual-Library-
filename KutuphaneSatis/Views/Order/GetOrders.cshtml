@model List<KutuphaneSatis.DTOs.Response.OrderResponse.OrderHistoryResponse>
@{
    ViewData["Title"] = "Siparişlerim";
}
<div class="container mt-5 mb-5">
    <h2 class="text-primary fw-bold mb-3"><i class="bi bi-box-seam"></i> Geçmiş Siparişlerim</h2>
    <hr class="mb-4" />

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info shadow-sm border-0 rounded-4 p-5 text-center">
            <h5 class="fw-bold text-info-emphasis mb-0">Henüz bir siparişiniz bulunmamaktadır.</h5>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded-4 border">
            <table class="table table-hover align-middle mb-0 bg-white">
                <thead class="table-dark">
                    <tr>
                        <th class="py-3 px-4">Sipariş Numarası</th>
                        <th class="py-3">Tarih</th>
                        <th class="py-3">Toplam Tutar</th>
                        <th class="py-3 text-center px-4">Detaylar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="fw-bold px-4 fs-5 text-secondary">#@order.OrderId</td>
                            <td class="fw-semibold text-dark">@order.OrderTime.ToString("dd.MM.yyyy")</td>
                            <td><span class="badge bg-success fs-5 shadow-sm px-3 py-2">@order.TotalPrice ₺</span></td>
                            <td class="text-center px-4">
                                <a asp-controller="Order" asp-action="GetOrderDetails" asp-route-id="@order.OrderId" class="btn btn-outline-primary fw-bold shadow-sm px-4 py-2 rounded-pill">
                                    Detayları Gör
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>