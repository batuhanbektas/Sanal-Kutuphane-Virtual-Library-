@model KutuphaneSatis.DTOs.Response.CartResponses.CartResponse

@{
    ViewData["Title"] = "Sepetim";
}

<div class="container mt-5">
    <h2><i class="bi bi-cart"></i> Sepetim</h2>
    <hr />

    @* 1. DURUM: Sepet Boş veya Hiç Ürün Yoksa *@
    @if (Model == null || Model.CartItems == null || !Model.CartItems.Any())
    {
        <div class="alert alert-info text-center">
            <h4>Sepetinizde henüz ürün bulunmuyor.</h4>
            <p>Hemen kitaplarımıza göz atıp sepetinizi doldurmaya başlayabilirsiniz!</p>
            <a href="/Home/Index" class="btn btn-primary mt-2">Alışverişe Başla</a>
        </div>
    }
    @* 2. DURUM: Sepette Ürün Varsa *@
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Kitap Adı</th>
                        <th style="width: 150px;">Adet</th>
                        <th>Toplam Fiyat</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.CartItems)
                    {
                        <tr>
                            <td>@item.BookName</td>

                            <td>
                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="d-flex">
                                    <input type="hidden" name="cartDetailId" value="@item.cartitemid" />

                                    <input type="number" name="newQuantity" value="@item.Quantity" min="1" class="form-control form-control-sm me-2" />
                                    <button type="submit" class="btn btn-sm btn-success">Yenile</button>
                                </form>

                                <form asp-controller="Cart" asp-action="RemoveItem" method="post" style="display:inline;">
                                    <input type="hidden" name="cartDetailId" value="@item.cartitemid" />
                                    <button type="submit" class="btn btn-success btn-sm">
                                        sepetten cikar
                                    </button>
                                </form>
                            </td>

                            <td>@item.UnitPrice.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card mt-4 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">

                <form asp-controller="Cart" asp-action="ClearCart" method="post">
                    <input type="hidden" name="cartId" value="@Model.CartItems.First().CartId" />
                    <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Sepeti tamamen boşaltmak istediğinize emin misiniz?');">
                        <i class="bi bi-trash"></i> Sepeti Boşalt
                    </button>
                </form>

                <h4 class="mb-0 text-success">Genel Toplam: @Model.TotalPrice.ToString("C")</h4>

                <form asp-controller="Cart" asp-action="CreateOrder" method="post">
                    <button type="submit" class="btn btn-primary btn-lg">Satın Al</button>
                </form>
                <form asp-controller="Cart" asp-action="CreateRent" method="post">
                    <button type="submit" class="btn btn-primary btn-lg">Kirala</button>
                </form>

            </div>
        </div>
    }
</div>