@model KutuphaneSatis.DTOs.Response.CartResponses.CartResponse
@{
    ViewData["Title"] = "Sepetim";
}
<div class="container mt-5 mb-5">
    <h2 class="text-primary fw-bold mb-3"><i class="bi bi-cart3"></i> Sepetim</h2>
    <hr class="mb-4" />
    @if (Model == null || Model.CartItems == null || !Model.CartItems.Any())
    {
        <div class="alert alert-info shadow-sm border-0 rounded-4 p-5 text-center">
            <h4 class="fw-bold text-info-emphasis mb-3">Sepetinizde henüz ürün bulunmuyor.</h4>
            <p class="text-muted fs-5 mb-4">Hemen kitaplarımıza göz atıp sepetinizi doldurmaya başlayabilirsiniz!</p>
            <a href="/api/Book/GetCatalog" class="btn btn-primary btn-lg shadow-sm px-5 rounded-pill fw-semibold">Alışverişe Başla</a>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded-4 border mb-4">
            <table class="table table-hover align-middle mb-0 bg-white">
                <thead class="table-dark">
                    <tr>
                        <th class="py-3 px-4">Kitap Adı</th>
                        <th class="py-3 text-center" style="width: 250px;">Adet</th>
                        <th class="py-3 text-end px-4">Toplam Fiyat</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.CartItems)
                    {
                        <tr>
                            <td class="fw-semibold px-4 text-dark fs-5">@item.BookName</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center align-items-center gap-2">
                                    <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="d-flex">
                                        <input type="hidden" name="cartDetailId" value="@item.cartitemid" />
                                        <div class="input-group input-group-sm shadow-sm">
                                            <input type="number" name="newQuantity" value="@item.Quantity" min="1" class="form-control text-center fw-bold" style="width: 70px;" />
                                            <button type="submit" class="btn btn-primary fw-semibold px-3">Yenile</button>
                                        </div>
                                    </form>
                                    <form asp-controller="Cart" asp-action="RemoveItem" method="post">
                                        <input type="hidden" name="cartDetailId" value="@item.cartitemid" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm shadow-sm fw-bold px-3 py-1">
                                            Sil
                                        </button>
                                    </form>
                                </div>
                            </td>
                            <td class="text-end px-4 fw-bold text-success fs-5">@item.UnitPrice.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-4 d-flex flex-column flex-md-row justify-content-between align-items-center bg-light rounded-4">
                <form asp-controller="Cart" asp-action="ClearCart" method="post" class="mb-3 mb-md-0">
                    <input type="hidden" name="cartId" value="@Model.CartItems.First().CartId" />
                    <button type="submit" class="btn btn-outline-danger shadow-sm fw-bold px-5 py-2 rounded-pill" onclick="return confirm('Sepeti tamamen boşaltmak istediğinize emin misiniz?');">
                        Sepeti Boşalt
                    </button>
                </form>
                <div class="d-flex flex-column flex-md-row align-items-center gap-4">
                    <div class="text-center text-md-end border-end pe-md-4">
                        <span class="text-muted fw-semibold">Genel Toplam</span>
                        <h3 class="mb-0 text-success fw-bold display-6">@Model.TotalPrice.ToString("C")</h3>
                    </div>
                    <div class="d-flex gap-3">
                        <form asp-controller="Cart" asp-action="CreateRent" method="post">
                            <button type="submit" class="btn btn-warning btn-lg shadow-sm fw-bold px-5 rounded-pill text-dark">Kirala</button>
                        </form>
                        <form asp-controller="Cart" asp-action="CreateOrder" method="post">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm fw-bold px-5 rounded-pill">Satın Al</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>