@model KutuphaneSatis.DTOs.Request.UserRequest.UserRegisterRequest
@{
    ViewData["Title"] = "Kayıt Ol";
}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-success text-white py-4 rounded-top-4 text-center border-0">
                    <h3 class="mb-0 fw-bold"><i class="bi bi-person-plus"></i> Sisteme Kayıt Ol</h3>
                </div>
                <div class="card-body p-5 bg-white rounded-bottom-4">

                    <form asp-controller="User" asp-action="Register" method="post">

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-secondary">Adınız</label>
                            <input asp-for="Name" class="form-control form-control-lg bg-light border-0 shadow-sm" placeholder="Adınızı giriniz" />
                            <span asp-validation-for="Name" class="text-danger fw-semibold small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Surname" class="form-label fw-bold text-secondary">Soyadınız</label>
                            <input asp-for="Surname" class="form-control form-control-lg bg-light border-0 shadow-sm" placeholder="Soyadınızı giriniz" />
                            <span asp-validation-for="Surname" class="text-danger fw-semibold small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-bold text-secondary">E-Posta Adresi</label>
                            <input asp-for="Email" class="form-control form-control-lg bg-light border-0 shadow-sm" placeholder="ornek@domain.com" />
                            <span asp-validation-for="Email" class="text-danger fw-semibold small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold text-secondary">Şifre Belirleyin</label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg bg-light border-0 shadow-sm" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger fw-semibold small mt-1 d-block"></span>
                        </div>

                        <div class="d-grid mt-5">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm fw-bold rounded-pill">Ücretsiz Kayıt Ol</button>
                        </div>
                    </form>

                    <div class="text-center mt-4 pt-3 border-top">
                        <span class="text-muted">Zaten bir hesabınız var mı?</span>
                        <a href="/User/Login" class="text-success fw-bold text-decoration-none ms-1">Giriş Yapın</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}