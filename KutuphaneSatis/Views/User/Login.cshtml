@model KutuphaneSatis.DTOs.Request.UserRequest.UserLoginRequest
@{
    ViewData["Title"] = "Giriş Yap";
}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white py-4 rounded-top-4 text-center border-0">
                    <h3 class="mb-0 fw-bold"><i class="bi bi-person-lock"></i> Sanal Kütüphane Giriş</h3>
                </div>
                <div class="card-body p-5 bg-white rounded-bottom-4">

                    <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

                    <form asp-action="Login" method="post">
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">E-posta Adresi</label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg bg-light border-0 shadow-sm" placeholder="ornek@domain.com" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">Şifre</label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg bg-light border-0 shadow-sm" placeholder="••••••••" required />
                        </div>

                        <div class="d-grid mt-5">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm fw-bold rounded-pill">Sisteme Giriş Yap</button>
                        </div>
                    </form>

                    <div class="text-center mt-4 pt-3 border-top">
                        <span class="text-muted">Hesabınız yok mu?</span>
                        <a href="/User/Register" class="text-primary fw-bold text-decoration-none ms-1">Hemen Kayıt Olun</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>