@model KutuphaneSatis.DTOs.Response.UserResponse.UserProfileResponse
@{
    ViewData["Title"] = "Profilim";
}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 text-center">
                <div class="card-header bg-dark text-white py-4 rounded-top-4 border-0">
                    <h4 class="mb-0 fw-bold">Kullanıcı Profili</h4>
                </div>
                <div class="card-body p-5 bg-white rounded-bottom-4">

                    <div class="mb-4">
                        <div class="bg-primary text-white rounded-circle d-inline-flex justify-content-center align-items-center shadow" style="width: 80px; height: 80px;">
                            <i class="bi bi-person-fill display-4"></i>
                        </div>
                    </div>

                    <div class="mb-4 bg-light p-3 rounded-3 shadow-sm">
                        <label class="form-label text-muted fw-bold small mb-1 text-uppercase">Ad Soyad</label>
                        <div class="fs-4 fw-bold text-dark">@Model.Name @Model.Surname</div>
                    </div>

                    <div class="mb-5 bg-light p-3 rounded-3 shadow-sm">
                        <label class="form-label text-muted fw-bold small mb-1 text-uppercase">E-Posta Adresi</label>
                        <div class="fs-5 text-secondary fw-semibold">@Model.Email</div>
                    </div>

                    <div class="d-grid gap-3 mt-4">
                        <a href="/Home/Index" class="btn btn-outline-secondary btn-lg shadow-sm fw-bold rounded-pill">
                            Ana Sayfaya Dön
                        </a>
                        <a href="/User/LogOut" class="btn btn-danger btn-lg shadow-sm fw-bold rounded-pill">
                            Güvenli Çıkış Yap
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>