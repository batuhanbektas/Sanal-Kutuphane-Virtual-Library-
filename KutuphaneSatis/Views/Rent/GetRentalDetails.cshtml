@model KutuphaneSatis.DTOs.Response.RentResponse.RentalDetailResponse

@{
    ViewData["Title"] = "Kiralama Detayı";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Kiralama İşlemi Detayı</h2>
        <a asp-controller="Rent" asp-action="GetRents" class="btn btn-secondary">Kiralamalarıma Dön</a>
    </div>
    <hr />

    <div class="card mb-4 shadow-sm border-primary">
        <div class="card-body bg-light">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-1"><strong>Başlangıç Tarihi:</strong> @Model.RStartTime.ToString("dd.MM.yyyy")</p>
                    <p class="mb-1">
                        <strong>Bitiş Tarihi:</strong>
                        @(Model.REndTime != DateOnly.MinValue ? Model.REndTime.ToString("dd.MM.yyyy") : "Henüz Teslim Edilmedi")
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <h4 class="mb-0 mt-3 mt-md-0">Toplam Tutar: <span class="text-success fw-bold">@Model.TotalPrice ₺</span></h4>
                </div>
            </div>
        </div>
    </div>

    <h4 class="mt-4"><i class="bi bi-book"></i> Kiralanan Kitaplar</h4>
    <table class="table table-bordered mt-3 shadow-sm">
        <thead class="table-secondary">
            <tr>
                <th>Kitap Adı</th>
                <th class="text-center">Kiralanan Adet</th>
                <th class="text-center">Süre (Gün)</th>
                <th class="text-center">Birim Fiyat</th>
                <th class="text-center">İade Edilen</th>
                <th class="text-center">İşlem</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.RentItem != null && Model.RentItem.Any())
            {
                @foreach (var item in Model.RentItem)
                {
                    <tr>
                        <td class="align-middle">@item.BookName</td>
                        <td class="align-middle text-center">@item.RentalQuantity</td>
                        <td class="align-middle text-center">@item.RentalDurationDays Gün</td>
                        <td class="align-middle text-center">@item.UnitPrice ₺</td>
                        <td class="align-middle text-center">
                            @if (item.ReturnedQuantitiy == item.RentalQuantity)
                            {
                                <span class="badge bg-success">Tümü İade Edildi (@item.ReturnedQuantitiy)</span>
                            }
                            else if (item.ReturnedQuantitiy > 0)
                            {
                                <span class="badge bg-warning text-dark">Eksik İade (@item.ReturnedQuantitiy)</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">İade Edilmedi (0)</span>
                            }
                        </td>

                        <td class="align-middle text-center">
                            @if (item.ReturnedQuantitiy < item.RentalQuantity)
                            {
                                <form asp-controller="Rent" asp-action="ReturnRents" method="post" class="d-flex justify-content-center align-items-center">

                                    <input type="hidden" name="rentBookId" value="@item.RentalBookId" />

                                    <input type="number" name="quantity" class="form-control form-control-sm me-2"
                                           style="width: 70px;" min="1" max="@(item.RentalQuantity - item.ReturnedQuantitiy)" value="1" />

                                    <button type="submit" class="btn btn-sm btn-outline-primary">İade Et</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted fw-bold"><i class="bi bi-check2-all"></i> İşlem Tamam</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">Bu işleme ait kitap detayı bulunamadı.</td>
                </tr>
            }
        </tbody>
    </table>
</div>