@model KutuphaneSatis.DTOs.Request.BookRequest.CreateBookRequest
@{
    ViewData["Title"] = "Yeni Kitap Ekle";
}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white py-4 rounded-top-4">
                    <h4 class="mb-0 fw-bold text-center">Yeni Kitap Ekle</h4>
                </div>
                <div class="card-body p-5 bg-white">
                    <form action="/api/Book/AddBook" method="post">

                        <div class="mb-4">
                            <label for="Name" class="form-label fw-bold text-secondary">Kitap Adı</label>
                            <input type="text" class="form-control form-control-lg bg-light border-0 shadow-sm" id="Name" name="Name" required />
                        </div>

                        <div class="mb-4">
                            <label for="AuthorName" class="form-label fw-bold text-secondary">Yazar Adı</label>
                            <input type="text" class="form-control bg-light border-0 shadow-sm" id="AuthorName" name="AuthorName" required />
                        </div>

                        <div class="mb-4">
                            <label for="CategoryId" class="form-label fw-bold text-secondary">Kategori</label>
                            <div class="input-group shadow-sm rounded-3">
                                <select name="CategoryId" class="form-select bg-light border-0" required>
                                    <option value="">Lütfen bir kategori seçin...</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        foreach (var category in ViewBag.Categories)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    }
                                </select>
                                <a href="/api/Category/ManageCategory" class="btn btn-primary fw-bold px-4">Kategoriler</a>
                            </div>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-4">
                                <label for="PageNumber" class="form-label fw-bold text-secondary">Sayfa Sayısı</label>
                                <input type="number" class="form-control bg-light border-0 shadow-sm" id="PageNumber" name="PageNumber" min="0" value="0" required />
                            </div>
                            <div class="col-md-4">
                                <label for="Stock" class="form-label fw-bold text-secondary">Stok Adedi</label>
                                <input type="number" class="form-control bg-light border-0 shadow-sm" id="Stock" name="Stock" min="0" value="0" required />
                            </div>
                            <div class="col-md-4">
                                <label for="Price" class="form-label fw-bold text-secondary">Fiyat (TL)</label>
                                <input type="number" class="form-control bg-light border-0 shadow-sm" id="Price" name="Price" step="0.01" min="0" required />
                            </div>
                        </div>

                        <div class="mb-5">
                            <label for="Description" class="form-label fw-bold text-secondary">Açıklama</label>
                            <textarea class="form-control bg-light border-0 shadow-sm" id="Description" name="Description" rows="4"></textarea>
                        </div>

                        <div class="d-flex justify-content-end gap-3">
                            <a href="/api/Book/GetCatalog" class="btn btn-secondary px-5 py-2 fw-semibold shadow-sm rounded-pill">İptal</a>
                            <button type="submit" class="btn btn-success px-5 py-2 fw-bold shadow-sm rounded-pill">Kitabı Kaydet</button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>