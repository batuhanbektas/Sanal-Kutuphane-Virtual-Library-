@model List<KutuphaneSatis.DTOs.Response.BookResponse.BookListItemResponse>

<h2>Sanal Kütüphane - Kitap Kataloğu</h2>
<hr />

<div class="d-flex justify-content-between mb-3">
    <div>
        <a href="/api/Book/AddBook" class="btn btn-success">+ Yeni Kitap Ekle</a>
        <a href="/api/Book/RemoveBook" class="btn btn-warning">Toplu Silme Paneli</a>
    </div>

    <form action="/api/Book/GetCatalog" method="get" class="d-flex">
        <select name="categoryId" class="form-select me-2">
            <option value="">Tüm Kategoriler</option>
            @if (ViewBag.Categories != null)
            {
                foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            }
        </select>
        <button type="submit" class="btn btn-primary">Filtrele</button>
    </form>
</div>

<table class="table border">
    <thead>
        <tr>
            <th>Kitap Adı</th>
            <th>Fiyat</th>
            <th>Stok Adedi</th>
            <th>Kategori</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Name</td>
                    <td>@book.Price ₺</td>
                    <td>@book.Stock</td>
                    <td>@book.CatName</td>
                    <td>
                        <a href="/api/Book/@book.BookId" class="btn btn-info btn-sm">Detayları Gör</a>

                        <a href="/api/Book/EditBook/@book.BookId" class="btn btn-warning btn-sm text-dark">Düzenle</a>

                        <form method="post" action="/api/Book/RemoveBook" style="display:inline;">
                            <input type="hidden" name="bookId" value="@book.BookId" />
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Bu kitabı silmek istediğinize emin misiniz?');">
                                Sil
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">Henüz kayıtlı kitap bulunamadı.</td>
            </tr>
        }
    </tbody>
</table>